# Supabase — get these from your project settings at https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# Stripe — get these from https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOCIAL_MONTHLY=

# Google AI Studio — get an API key from https://aistudio.google.com/api-key
# Powers both screenshot image extraction (Gemini) and AI video generation (Veo)
GEMINI_API_KEY=
# Optional: override the Veo model used for video generation (default: veo-3.0-generate-001)
VEO_MODEL=

# App URL (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=https://some-rental123.vercel.app
